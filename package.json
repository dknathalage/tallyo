{
  "name": "tallyo",
  "version": "2.1.1",
  "description": "Self-hosted invoice manager desktop app.",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite dev",
    "dev:docs": "TALLYO_TARGET=docs vite dev",
    "build": "vite build",
    "build:docs": "TALLYO_TARGET=docs vite build",
    "start": "npm run electron:dev",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "verify": "npm run check && npm run lint && npm test",
    "electron:rebuild": "electron-builder install-app-deps",
    "electron:dev": "npm run build && electron .",
    "electron:pack": "npm run build && electron-builder --dir",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.44.0",
    "get-port": "^7.1.0",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "mdsvex": "^0.12.6",
    "papaparse": "^5.5.3",
    "tailwindcss": "^4.2.1",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/better-sqlite3": "^7.6.12",
    "@types/papaparse": "^5.5.2",
    "@vitest/coverage-v8": "^4.1.0",
    "drizzle-kit": "^0.31.0",
    "electron": "^41.5.0",
    "electron-builder": "^25.1.8",
    "eslint": "^10.2.1",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.5.0",
    "svelte": "^5.51.0",
    "svelte-check": "^4.3.6",
    "svelte-eslint-parser": "^1.6.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  }
}
